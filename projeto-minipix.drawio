        <mxCell id="2MsGO3TslsKYPyUmYsML-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;MINIPIX - API DE CONTAS BANCÁRIAS&lt;/span&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Regras de Negócio&lt;/h1&gt;&lt;div&gt;- Todas as contas possuem saldo e limite diário&lt;/div&gt;&lt;div&gt;- Nome do Titular e CPF são obrigatórios&lt;/div&gt;&lt;div&gt;- Somente usuários AUTENTICADOS podem acessar a API&lt;/div&gt;&lt;div&gt;- Saldo e limite diário devem ser valores positivos&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="450" x="40" y="40" as="geometry" />
        </mxCell>
        <mxCell id="2MsGO3TslsKYPyUmYsML-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Fluxo da Aplicação&lt;/span&gt;&lt;/h1&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. Usuário faz login com &lt;b&gt;Auth0&lt;/b&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. Auth0 retorna um &lt;b&gt;JWT&lt;/b&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3. Cliente envia requisições com &lt;b&gt;token &lt;/b&gt;no &lt;b&gt;header&lt;/b&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4. &lt;b&gt;API &lt;/b&gt;valida o token&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;5. &lt;b&gt;Controller &lt;/b&gt;processa e chama o &lt;b&gt;Service&lt;/b&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;6. &lt;b&gt;Service&lt;/b&gt;&amp;nbsp;aplica as regras e chama o &lt;b&gt;Repository.&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="300" x="430" y="100" as="geometry" />
